# ── App credentials ───────────────────────────────────────────────────────────
# Override the WDIO Native Demo App defaults (test@webdriver.io / Test1234!)
# Only required when pointing to a real app with actual authentication.
USERNAME="test@webdriver.io"
PASSWORD="Test1234!"

# ── Target platform ───────────────────────────────────────────────────────────
# android | ios
PLATFORM="android"

# ── App identifiers (only required when using a real app, not the demo app) ───
# Android App Package (e.g. com.example.app). Demo app: com.wdiodemoapp
APP_ID=""
# iOS Bundle Identifier (e.g. com.example.app). Check Info.plist inside .app bundle.
BUNDLE_ID=""

# ── Device unlock (Appium unlocks the emulator/device before the session) ─────
UNLOCK_KEY="1234"

# ── Android device overrides (optional – defaults work for a standard AVD) ────
# ANDROID_PLATFORM_VERSION="13.0"
# ANDROID_DEVICE_NAME="sdk_gphone64_arm64"
# ANDROID_UDID="emulator-5554"

# ── iOS device overrides (optional – defaults work for a standard simulator) ──
# IOS_PLATFORM_VERSION="18.5"
# IOS_DEVICE_NAME="iPhone 16"
